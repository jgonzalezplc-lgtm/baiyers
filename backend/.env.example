SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_SERVICE_KEY=tu-service-key
GEMINI_API_KEY=tu-gemini-key
SERP_API_KEY=tu-serp-key
ANTHROPIC_API_KEY=tu-anthropic-key
ENVIRONMENT=development

# Fuentes de distribuidores electrónicos (opcionales — si faltan, esa fuente se omite en la búsqueda)
# Mouser: https://www.mouser.com/api-search/ (registro gratis, key inmediata)
MOUSER_API_KEY=

# DigiKey: https://developer.digikey.com/ (crear Organization App, Product Information API v4)
DIGIKEY_CLIENT_ID=
DIGIKEY_CLIENT_SECRET=

# TME: https://developers.tme.eu/en/ (Token + App Secret)
TME_API_KEY=
TME_API_SECRET=

# Retail/ferretería Chile (Sodimac, Easy, La Sierra, Construmart) — no requieren API key,
# usan endpoints públicos de cada tienda (ver app/services/fuentes/retail_cl.py)
